# =============================================================================
# .github/workflows/docker-publish.yml for {{ project_name_title }}
# Generated by PyWatson — https://github.com/isaac-tes/pywatson
#
# Builds the Docker image and pushes it to GitHub Container Registry (GHCR).
# Triggers on:
#   - push to main (tagged as :latest and :sha)
#   - semver tags v*.*.* (tagged as :v1.2.3 and :latest)
# =============================================================================

name: Build & Publish Docker Image

on:
  push:
    branches:
      - main
    tags:
      - "v*.*.*"

env:
  REGISTRY: ghcr.io
  IMAGE_NAME: {% raw %}${{ github.repository }}{% endraw %}

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      # ------------------------------------------------------------------
      # Log in to GitHub Container Registry
      # ------------------------------------------------------------------
      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: {% raw %}${{ env.REGISTRY }}{% endraw %}
          username: {% raw %}${{ github.actor }}{% endraw %}
          password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}

      # ------------------------------------------------------------------
      # Compute image tags (SHA + latest / semver)
      # ------------------------------------------------------------------
      - name: Extract metadata (tags, labels)
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: {% raw %}${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}{% endraw %}
          tags: |
            type=sha,prefix=
            type=semver,pattern={{version}}
            type=raw,value=latest,enable={{is_default_branch}}

      # ------------------------------------------------------------------
      # Build the image
      # ------------------------------------------------------------------
      - name: Build Docker image
        id: build
        uses: docker/build-push-action@v5
        with:
          context: .
          push: false
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
          load: true

      # ------------------------------------------------------------------
      # Smoke-test: run the container against generated sample data
      # ------------------------------------------------------------------
      - name: Install uv for smoke-test data generation
        uses: astral-sh/setup-uv@v4

      - name: Generate sample data for smoke-test
        run: |
          uv sync
          uv run python scripts/generate_data.py
          mkdir -p plots

      - name: Smoke-test — run analysis inside container
        run: |
          docker run --rm \
            -v "$PWD/data":/workspace/data:ro \
            -v "$PWD/plots":/workspace/plots \
            $(echo {% raw %}"${{ steps.meta.outputs.tags }}"{% endraw %} | head -1)

      - name: Verify plots were generated
        run: |
          if [ -z "$(ls -A plots/)" ]; then
            echo "ERROR: plots/ is empty after smoke-test"
            exit 1
          fi
          echo "Smoke-test passed — plots generated:"
          ls -lh plots/

      # ------------------------------------------------------------------
      # Push to GHCR (only after smoke-test passes)
      # ------------------------------------------------------------------
      - name: Push Docker image to GHCR
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
