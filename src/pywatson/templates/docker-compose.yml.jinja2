# =============================================================================
# docker-compose.yml for {{ project_name_title }}
# Generated by PyWatson — https://github.com/isaac-tes/pywatson
#
# ONE-LINER REPRODUCTION WORKFLOW:
#   1. Download data archive from Zenodo and unpack into ./data/
#   2. docker compose run reproduce
#   3. Plots appear in ./plots/
# =============================================================================

services:
  # ---------------------------------------------------------------------------
  # reproduce: re-run the full analysis pipeline from Zenodo data
  # ---------------------------------------------------------------------------
  reproduce:
    build: .
    image: {{ project_name }}:latest
    # Mount local data (read-only) and plots (read-write)
    volumes:
      - ./data:/workspace/data:ro
      - ./plots:/workspace/plots
    # Run the analysis entrypoint
    entrypoint: ["uv", "run", "python", "scripts/analyze_data.py"]

  # ---------------------------------------------------------------------------
  # shell: interactive debug session inside the container
  # ---------------------------------------------------------------------------
  shell:
    build: .
    image: {{ project_name }}:latest
    volumes:
      - ./data:/workspace/data:ro
      - ./plots:/workspace/plots
      - ./scripts:/workspace/scripts
    entrypoint: ["/bin/bash"]
    stdin_open: true
    tty: true
