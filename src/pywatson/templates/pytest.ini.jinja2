# pytest configuration for {{ project_name_title }}
#
# This file configures pytest for the project. You can also put these
# settings in pyproject.toml under [tool.pytest.ini_options].
#
# Usage:
#   uv run pytest                    # Run all tests
#   uv run pytest tests/ -v         # Verbose output
#   uv run pytest -k "keyword"      # Run tests matching keyword
#   uv run pytest --cov=src/{{ package_name }}  # With coverage

[pytest]
# Directories to search for tests
testpaths = tests

# Naming conventions for test discovery
python_files = test_*.py
python_classes = Test*
python_functions = test_*

# Default command-line options
# -v: verbose output
# --tb=short: shorter tracebacks
addopts = -v --tb=short

# Markers for categorising tests
markers =
    slow: marks tests as slow (deselect with '-m "not slow"')
    integration: marks integration tests that may require external resources
    data: marks tests that create or load data files
